{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "Clients": {
      "type": "object",
      "properties": {
        "FirstClient": {
          "type": "object",
          "description": "Configuration for FirstClient.",
