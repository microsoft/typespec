{
  "name": "@typespec/http-client-py",
  "version": "0.1.0",
  "type": "module",
  "homepage": "https://typespec.io",
  "readme": "https://github.com/microsoft/typespec/blob/main/packages/http-client-py/README.md",
  "main": "dist/src/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/microsoft/typespec.git"
  },
  "bugs": {
    "url": "https://github.com/microsoft/typespec/issues"
  },
  "scripts": {
    "build": "alloy build",
    "clean": "rimraf ./dist",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "watch": "alloy build --watch",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:watch": "vitest -w",
    "test:ci": "vitest run --coverage --reporter=junit --reporter=default",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "exports": {
    ".": {
      "import": "./dist/src/index.js"
    },
    "./testing": {
      "import": "./dist/src/testing/index.js"
    },
    "./components": {
      "import": "./dist/src/components/index.js"
    }
  },
  "bin": {
    "tsp-py-postprocess": "./dist/src/bin/post-process.js"
  },
  "keywords": [
    "typespec",
    "python"
  ],
  "author": "Microsoft Corporation",
  "license": "MIT",
  "description": "TypeSpec library for emitting Http Client libraries for Python (alloy + emitter-framework based).",
  "peerDependencies": {
    "@typespec/compiler": "workspace:^",
    "@typespec/http": "workspace:^",
    "@typespec/rest": "workspace:^"
  },
  "dependencies": {
    "@alloy-js/core": "catalog:",
    "@alloy-js/python": "catalog:",
    "@typespec/emitter-framework": "workspace:^",
    "@typespec/http-client": "workspace:^",
    "pyodide": "catalog:"
  },
  "devDependencies": {
    "@alloy-js/cli": "catalog:",
    "@alloy-js/rollup-plugin": "catalog:",
    "@typespec/compiler": "workspace:^",
    "@typespec/http": "workspace:^",
    "@typespec/rest": "workspace:^",
    "@vitest/ui": "catalog:",
    "rimraf": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
