{
  "extends": "../../tsconfig.base.json",
  "references": [
    { "path": "../compiler/tsconfig.build.json" },
    { "path": "../rest/tsconfig.build.json" },
    { "path": "../openapi/tsconfig.build.json" },
    { "path": "../openapi3/tsconfig.build.json" }
  ],
  "compilerOptions": {
    "outDir": "dist-dev",
    "rootDir": ".",
    "skipLibCheck": true,
    "tsBuildInfoFile": "temp/tsconfig.tsbuildinfo",
    "jsx": "react-jsx",
    "checkJs": true,
    "allowJs": true,
    "lib": ["DOM", "ES2022"],
    "types": ["vite/client"]
  },
  "include": ["src/", "test/**/*.ts", "e2e/**/*.ts", "vite.config.ts", "samples/dist/samples.ts"]
}
