{
  "name": "@typespec/spector",
  "version": "0.1.0-alpha.25",
  "description": "Typespec Core Tool to validate, run mock api, collect coverage.",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "typespec": "./lib/main.tsp"
    }
  },
  "type": "module",
  "bin": {
    "tsp-spector": "./cmd/cli.mjs"
  },
  "scripts": {
    "watch": "tsc -p ./tsconfig.build.json --watch",
    "build": "pnpm gen-extern-signature && tsc -p tsconfig.build.json",
    "clean": "rimraf dist/ temp/",
    "gen-extern-signature": "tspd --enable-experimental gen-extern-signature .",
    "test": "vitest run",
    "test:watch": "vitest -w",
    "test:ui": "vitest --ui"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/microsoft/typespec.git"
  },
  "author": "Microsoft",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/microsoft/typespec/issues"
  },
  "homepage": "https://github.com/microsoft/typespec#readme",
  "dependencies": {
    "@azure/identity": "catalog:",
    "@typespec/compiler": "workspace:^",
    "@typespec/http": "workspace:^",
    "@typespec/rest": "workspace:^",
    "@typespec/spec-api": "workspace:^",
    "@typespec/spec-coverage-sdk": "workspace:^",
    "@typespec/versioning": "workspace:^",
    "ajv": "catalog:",
    "express": "catalog:",
    "globby": "catalog:",
    "micromatch": "catalog:",
    "morgan": "catalog:",
    "multer": "catalog:",
    "picocolors": "catalog:",
    "source-map-support": "catalog:",
    "yaml": "catalog:",
    "yargs": "catalog:"
  },
  "devDependencies": {
    "@types/express": "catalog:",
    "@types/micromatch": "catalog:",
    "@types/morgan": "catalog:",
    "@types/multer": "catalog:",
    "@types/node": "catalog:",
    "@types/yargs": "catalog:",
    "@typespec/tspd": "workspace:^",
    "rimraf": "catalog:",
    "typescript": "catalog:"
  }
}
