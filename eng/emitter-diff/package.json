{
  "name": "@typespec/emitter-diff",
  "version": "0.1.0",
  "private": true,
  "description": "Diff generated code across TypeSpec emitter versions and run generated-code tests, for all language emitters in this repo.",
  "type": "module",
  "main": "src/cli.ts",
  "bin": {
    "emitter-diff": "./src/cli.ts"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "emitter-diff": "tsx src/cli.ts",
    "build": "tsc -p .",
    "typecheck": "tsc -p ."
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
