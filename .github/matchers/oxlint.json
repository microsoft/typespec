{
  "problemMatcher": [
    {
      "owner": "oxlint",
      "severity": "error",
      "pattern": [
        {
          "regexp": "^(.+?):(\\d+):(\\d+):\\s+(.+?)\\s+\\[(Error|Warning)/(.+)\\]$",
          "file": 1,
          "line": 2,
          "column": 3,
          "message": 4,
          "severity": 5,
          "code": 6
        }
      ]
    }
  ]
}
